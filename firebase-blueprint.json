{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available for purchase",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string" },
        "name": { "type": "object" },
        "description": { "type": "object" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "tags": { "type": "array" },
        "order": { "type": "number" }
      },
      "required": ["categoryId", "name", "price"]
    },
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client", "user"] },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "name": { "type": "object" },
        "image": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "userContact": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "promocode": { "type": "string" },
        "status": { "type": "string" },
        "paymentScreenshot": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Promocode": {
      "title": "Promocode",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discount": { "type": "number" },
        "limit": { "type": "number" },
        "usedCount": { "type": "number" }
      }
    },
    "Settings": {
      "title": "Settings",
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "primaryColor": { "type": "string" },
        "aboutUs": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products catalog"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/promocodes/{promoCode}": {
      "schema": "Promocode",
      "description": "Discount codes"
    },
    "/settings/{docId}": {
      "schema": "Settings",
      "description": "Site-wide settings"
    }
  }
}
